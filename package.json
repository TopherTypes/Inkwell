{
  "name": "inkwell",
  "version": "0.1.0",
  "description": "A single-user desktop writing application",
  "main": "dist-electron/index.js",
  "homepage": "./",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:tsc\" \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:tsc": "tsc -p tsconfig.main.json --watch",
    "dev:vite": "sleep 1 && vite dev --host",
    "dev:electron": "sleep 2 && npm run move-main-output && node start-dev.js",
    "build": "tsc -p tsconfig.main.json && npm run move-main-output && vite build && electron-builder",
    "move-main-output": "mkdir -p dist-electron && mv dist-electron/main/* dist-electron/ 2>/dev/null || true && rm -rf dist-electron/main dist-electron/src 2>/dev/null || true",
    "preview": "electron dist-electron/index.js",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.main.json"
  },
  "dependencies": {
    "@tiptap/core": "^2.4.0",
    "@tiptap/extension-character-count": "^2.4.0",
    "@tiptap/extension-hard-break": "^2.4.0",
    "@tiptap/extension-image": "^2.4.0",
    "@tiptap/extension-placeholder": "^2.4.0",
    "@tiptap/extension-typography": "^2.4.0",
    "@tiptap/react": "^2.4.0",
    "@tiptap/starter-kit": "^2.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^10.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  }
}
